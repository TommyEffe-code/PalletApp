generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Department {
  id            String   @id @default(uuid())
  name          String   @unique
  password      String
  pallets       Pallet[]
}

model Pallet {
  id            String         @id @default(uuid())
  name          String
  section       String?        // Optional sub-category within a department (e.g. "Freschi", "Surgelati")
  status        String         @default("OPEN") // OPEN, CLOSED
  createdAt     DateTime       @default(now())
  departmentId  String
  department    Department     @relation(fields: [departmentId], references: [id])
  products      ProductEntry[]
}

model ProductEntry {
  id            String   @id @default(uuid())
  barcode       String
  name          String?  // Optional name from Open Food Facts
  imageUrl      String?  // Optional image from Open Food Facts
  quantity      Int      @default(1)
  isCase        Boolean  @default(false) // Whether this entry is a case or a single item
  createdAt     DateTime @default(now())
  palletId      String
  pallet        Pallet   @relation(fields: [palletId], references: [id], onDelete: Cascade)
}
